setcps (130 / 60/ 4)

d1
$ sometimes palindrome   
$ n (scale "dorian" $ "1 ~ 2 3 4 6  ~ 3 6 9 6 2 4 1 3 4" |-12 )
# sound "chainsaw"
# sustain "0.5 0.75 1.25"  
# gain "[0.1 1 1 1]*4"
# room (0.5 + (sine*0.25)) 
# gain 0.8

d2 $ n "[7 ~ ~ ~]*4" # s "909bd_v"

d2 silence

d3 $ s "909_sd_mpc:5(2,4)" # gain 0.75

d3 silence

d4 $ s "[909ch:3 909ch:3 909ch:1 909ch:1]*4" #  gain "[0.3 0.4]*8" # pan (0.4 + (rand * 0.2))
